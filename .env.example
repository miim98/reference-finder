# Google Gemini API 키 (이미지 → 키워드 5개 자동 추출용) — 무료
#  https://aistudio.google.com/app/apikey 에서 "Create API key" (카드 불필요)
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (선택) Gemini 모델 — 기본 gemini-2.0-flash
# GEMINI_MODEL=gemini-2.0-flash

# Google Programmable Search (키워드별 상위 이미지용) — 무료 하루 100회
#  1) https://programmablesearchengine.google.com/ 에서 검색엔진 생성 → 검색엔진 ID(cx)
#  2) https://console.cloud.google.com/ 에서 "Custom Search API" 사용 설정 후 API 키 발급
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CSE_ID=xxxxxxxxxxxxxxxxx

# (선택) Flask 개발 서버 포트 / 호스트
PORT=5000
HOST=127.0.0.1
