# Anthropic API 키 (이미지 → 키워드 자동 추출용). https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Programmable Search (키워드별 상위 이미지용) — 무료 하루 100회
#  1) https://programmablesearchengine.google.com/ 에서 검색엔진 생성("전체 웹 검색" 켜기) → 검색엔진 ID(cx)
#  2) https://console.cloud.google.com/ 에서 "Custom Search API" 사용 설정 후 API 키 발급
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CSE_ID=xxxxxxxxxxxxxxxxx

# (선택) Flask 개발 서버 포트 / 호스트
PORT=5000
HOST=127.0.0.1
