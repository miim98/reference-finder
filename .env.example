# Groq API 키 (이미지 → 키워드 5개 추출용) — 무료, Google 무관
#  https://console.groq.com/keys 에서 "Create API Key" (카드 불필요)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (선택) Groq vision 모델 — 기본 meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Pexels API 키 (키워드별 관련 이미지용) — 무료, 카드 불필요
#  https://www.pexels.com/api/ 에서 가입 후 API 키 발급. 없으면 사이트 검색 링크만 표시.
PEXELS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (선택) Flask 개발 서버 포트 / 호스트
PORT=5000
HOST=127.0.0.1
