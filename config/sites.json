{
  "max_keywords": 3,
  "results_per_site": 5,
  "request_timeout": 8,
  "sites": [
    {
      "name": "Pinterest",
      "search_url": "https://kr.pinterest.com/search/pins/?q={query}",
      "homepage": "https://kr.pinterest.com",
      "extract": {
        "enabled": true,
        "link_pattern": "/pin/\\d+/",
        "base_url": "https://kr.pinterest.com"
      }
    },
    {
      "name": "Behance",
      "search_url": "https://www.behance.net/search/projects?search={query}",
      "homepage": "https://www.behance.net",
      "extract": {
        "enabled": true,
        "link_pattern": "/gallery/\\d+/[A-Za-z0-9\\-]+",
        "base_url": "https://www.behance.net"
      }
    },
    {
      "name": "Cosmos",
      "search_url": "https://www.cosmos.so/search?q={query}",
      "homepage": "https://www.cosmos.so"
    },
    {
      "name": "Savee",
      "search_url": "https://savee.com/search/?q={query}",
      "homepage": "https://savee.com"
    }
  ]
}
